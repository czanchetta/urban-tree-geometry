# ---- Proprietary / private inventory data (never commit) ----
# Original client workbook and any real inventory are excluded by policy.
data/private/
*.xlsx
!outputs/**/*.xlsx
*_ORIGINAL*
PROJETO_*

# ---- Proprietary DIALux template objects (never commit) ----
# A .dxobj template is DIALux's own asset; the rewriter reads it at runtime
# from a user-supplied path. Generated exports also stay out of git.
*.dxobj
data/templates/
outputs/*.3ds
